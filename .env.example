SECRET_KEY=change-me
FLASK_ENV=development
FLASK_APP=wsgi.py

# local: SQLite (default). production: mysql+pymysql://user:pass@host:3306/route_mate
DATABASE_URL=sqlite:///route_mate.db

# 레이트 리밋 저장소(11.2절). 미설정 시 단일 프로세스 in-memory로 폴백(수평 확장 시 필수).
REDIS_URL=redis://localhost:6379/0

# PROFILE.allergy AES-256 암호화 키 — base64 인코딩된 32바이트 값 (11.3절).
# 생성 예: python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ALLERGY_ENCRYPTION_KEY=

# docker-compose용 MySQL 자격증명 (14.1절)
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me

# 지도 어댑터 (8.1/8.2절) — OpenStreetMap(Nominatim+OSRM) 공개 데모 서버, 키 불필요.
# 테스트/수업용 "합리적 사용" 정책 적용. false로 두면 Haversine 근사만 사용한다.
MAP_ADAPTER_ENABLED=true
# Nominatim/OSRM User-Agent에 포함할 연락처(정책 권장 사항)
MAP_CONTACT_EMAIL=
